# DeepSeek API 配置
# 申请地址：https://platform.deepseek.com/
# 注册送 ¥5 额度，deepseek-chat 模型 ¥1/百万tokens，超便宜
DEEPSEEK_API_KEY=sk-你的真实key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 向量库
CHROMA_PATH=./chroma_db
COLLECTION_NAME=ecommerce_service

# 数据集
DATA_PATH=./data/dianshang_sample.json
